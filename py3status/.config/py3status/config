# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
    colors = true
    interval = 5
    color_good = "#efaf8e"
    color_degraded = "#efb993"
    color_bad = "#e93c58"
}


order += "spotify"
order += "i3block weather"
# order += "disk /"
order += "wireless wlp2s0f0"
order += "battery 1"
order += "cpu_usage"
order += "volume_status"
order += "tztime local"

wireless wlp2s0f0 {
    format_up = "直%quality, %essid"
    format_down = "直 down"
}

ethernet eth0 {
    # if you use %speed, i3status requires root privileges
    format_up = "E: %ip (%speed)"
    format_down = "E: down"
}

battery 1 {
    last_full_capacity = true
    integer_battery_capacity = true
    hide_seconds = true
    # format = "%status %percentage %remaining"
    format = "%status %percentage"
    threshold_type = "percentage"
    low_threshold = 15
    status_bat = ""
    status_chr = ""
    status_full = ""
    status_unk = ""
}

run_watch DHCP {
    pidfile = "/var/run/dhclient*.pid"
}

run_watch VPN {
    pidfile = "/var/run/openvpn-client/*.pid"
}

tztime local {
    format = " %d.%m.%Y   %H:%M"
}

cpu_usage {
    max_threshold = 95
    degraded_threshold = 80
    format = " %usage"
}

volume master {
    format = " %volume"
    format_muted = " (muted) %volume"
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}

volume_status {
    format = " {percentage}%"
    format_muted = " muted"
    cache_timeout=0.5
}

disk "/" {
    format = " %avail"
}

i3block weather {
    command = "~/.config/i3/scripts/i3weather"
    interval = 120
}

spotify {
    button_next = 4
    button_play_pause = 1
    button_previous = 5
    format = " {artist} - {title}"
    format_stopped = " detenido"
    format_down = ""
}
